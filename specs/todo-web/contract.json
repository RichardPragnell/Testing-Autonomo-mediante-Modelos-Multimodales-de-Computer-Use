{
  "specId": "todo-web-v1",
  "version": 1,
  "displayName": "Todo Bench",
  "purpose": "Canonical functional contract for benchmark todo apps implemented in multiple web frameworks.",
  "implementationConstraints": [
    "Serve as a single-page local web app with no backend dependency.",
    "Keep state in memory only so every page reload resets to the same seeded todos.",
    "Keep user-visible copy, seeded data, scenario ids, and bug pack ids identical across framework ports.",
    "Allow implementation-specific component structure and styling, but preserve the accessible labels, button text, and flows defined here."
  ],
  "ui": {
    "documentTitle": "Todo Bench",
    "pageHeading": "Todo Bench",
    "heroEyebrow": "Benchmark Target",
    "heroLead": "Small todo app for local web QA runs, prompt-guided exploration, and bug-pack parity across frameworks.",
    "summaryCards": [
      {
        "label": "Remaining",
        "template": "{remaining} tasks remaining"
      },
      {
        "label": "Progress",
        "template": "{completed} of {total} tasks done"
      }
    ],
    "boardEyebrow": "Todo Flow",
    "boardHeading": "Task board",
    "filtersAriaLabel": "Todo filters",
    "filters": [
      {
        "key": "all",
        "label": "All"
      },
      {
        "key": "active",
        "label": "Active"
      },
      {
        "key": "completed",
        "label": "Completed"
      }
    ],
    "newTaskLabel": "New task",
    "newTaskPlaceholder": "Add a task for the benchmark run",
    "newTaskButton": "Add task",
    "editTaskLabel": "Edit task",
    "itemActions": {
      "edit": "Edit",
      "remove": "Remove",
      "save": "Save",
      "cancel": "Cancel"
    },
    "listAriaLabel": "Todo items"
  },
  "seed": {
    "entity": "todo",
    "fields": [
      "id",
      "text",
      "done"
    ],
    "initialTodos": [
      {
        "id": "todo-1",
        "text": "Plan todo benchmark",
        "done": false
      },
      {
        "id": "todo-2",
        "text": "Draft Stagehand checklist",
        "done": false
      }
    ]
  },
  "behavior": {
    "summary": [
      "Remaining count equals total todos minus completed todos.",
      "Progress text follows the template '{completed} of {total} tasks done'.",
      "Summary reflects the full todo list, not just the currently filtered subset."
    ],
    "addTask": [
      "Submitting a non-empty draft trims surrounding whitespace, appends one new todo, and clears the composer input.",
      "Submitting an empty or whitespace-only draft leaves the list unchanged."
    ],
    "toggleTask": [
      "Toggling a todo inverts its done state.",
      "Completion updates both summary cards and changes which filters include the item."
    ],
    "filtering": [
      "All shows every todo.",
      "Active shows only todos with done=false.",
      "Completed shows only todos with done=true."
    ],
    "editTask": [
      "Starting edit mode copies the selected todo text into the edit input.",
      "Saving an edit trims surrounding whitespace and persists the updated text if the result is non-empty.",
      "Cancelling an edit discards the draft and exits edit mode.",
      "Pressing Enter while editing saves the draft.",
      "Pressing Escape while editing cancels the draft."
    ],
    "removeTask": [
      "Removing a todo deletes it from the in-memory list immediately."
    ],
    "nonFeatures": [
      "No persistence across reloads.",
      "No bulk actions, ordering, due dates, or remote data."
    ]
  },
  "automationHooks": {
    "requiredAttributes": [
      {
        "element": "app root",
        "attribute": "data-bench",
        "value": "todo-app"
      },
      {
        "element": "composer form",
        "attribute": "data-bench",
        "value": "composer"
      },
      {
        "element": "new task input",
        "attribute": "data-bench",
        "value": "new-task-input"
      },
      {
        "element": "todo list",
        "attribute": "data-bench",
        "value": "todo-list"
      },
      {
        "element": "filter buttons",
        "attribute": "data-filter",
        "valueSet": [
          "all",
          "active",
          "completed"
        ]
      },
      {
        "element": "todo rows",
        "attribute": "data-todo-id",
        "dynamic": true
      },
      {
        "element": "action buttons and checkbox",
        "attribute": "data-action",
        "valueSet": [
          "add",
          "toggle",
          "edit",
          "remove",
          "save",
          "cancel"
        ]
      }
    ]
  },
  "scenarios": {
    "smoke-load": {
      "scenarioId": "smoke-load",
      "title": "Load the Todo Bench board",
      "source": "synthetic",
      "steps": [
        {
          "stepId": "smoke-load.assert-home",
          "title": "Verify the initial board copy",
          "assertions": [
            {
              "assertionId": "smoke-load.heading",
              "type": "extract",
              "instruction": "extract the main page heading text",
              "resultType": "string",
              "match": {
                "equals": "Todo Bench"
              }
            },
            {
              "assertionId": "smoke-load.remaining",
              "type": "extract",
              "instruction": "extract the text shown in the Remaining summary card",
              "resultType": "string",
              "match": {
                "equals": "2 tasks remaining"
              }
            },
            {
              "assertionId": "smoke-load.progress",
              "type": "extract",
              "instruction": "extract the text shown in the Progress summary card",
              "resultType": "string",
              "match": {
                "equals": "0 of 2 tasks done"
              }
            },
            {
              "assertionId": "smoke-load.seed-plan",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "includes": "Plan todo benchmark"
              }
            },
            {
              "assertionId": "smoke-load.seed-draft",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "includes": "Draft Stagehand checklist"
              }
            }
          ]
        }
      ]
    },
    "add-task": {
      "scenarioId": "add-task",
      "title": "Add a new task from the composer",
      "source": "generated",
      "steps": [
        {
          "stepId": "add-task.fill-composer",
          "title": "Fill the new task composer",
          "actionInstruction": "type Review benchmark notes into the New task input",
          "assertions": [
            {
              "assertionId": "add-task.composer-filled",
              "type": "extract",
              "instruction": "extract the current value of the New task input",
              "resultType": "string",
              "match": {
                "equals": "Review benchmark notes"
              }
            }
          ]
        },
        {
          "stepId": "add-task.submit",
          "title": "Submit the new task",
          "actionInstruction": "click the Add task button",
          "assertions": [
            {
              "assertionId": "add-task.remove-visible",
              "type": "observe",
              "instruction": "find the Remove button for the task Review benchmark notes",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "add-task.assert-outcome",
          "title": "Verify the new task and cleared composer",
          "assertions": [
            {
              "assertionId": "add-task.todo-visible",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "includes": "Review benchmark notes"
              }
            },
            {
              "assertionId": "add-task.composer-cleared",
              "type": "extract",
              "instruction": "extract whether the New task input is empty",
              "resultType": "boolean",
              "match": {
                "equals": true
              }
            }
          ]
        }
      ]
    },
    "complete-task": {
      "scenarioId": "complete-task",
      "title": "Complete an existing task",
      "source": "generated",
      "steps": [
        {
          "stepId": "complete-task.toggle",
          "title": "Toggle the Draft Stagehand checklist task",
          "actionInstruction": "click the checkbox for the task Draft Stagehand checklist",
          "assertions": [
            {
              "assertionId": "complete-task.active-filter-visible",
              "type": "observe",
              "instruction": "find the Active filter button",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "complete-task.assert-summary",
          "title": "Verify the completion summary",
          "assertions": [
            {
              "assertionId": "complete-task.progress",
              "type": "extract",
              "instruction": "extract the text shown in the Progress summary card",
              "resultType": "string",
              "match": {
                "equals": "1 of 2 tasks done"
              }
            }
          ]
        }
      ]
    },
    "filter-active": {
      "scenarioId": "filter-active",
      "title": "Show only active tasks",
      "source": "generated",
      "steps": [
        {
          "stepId": "filter-active.complete-one",
          "title": "Complete the Draft Stagehand checklist task",
          "actionInstruction": "click the checkbox for the task Draft Stagehand checklist",
          "assertions": [
            {
              "assertionId": "filter-active.progress",
              "type": "extract",
              "instruction": "extract the text shown in the Progress summary card",
              "resultType": "string",
              "match": {
                "equals": "1 of 2 tasks done"
              }
            }
          ]
        },
        {
          "stepId": "filter-active.select-active",
          "title": "Select the Active filter",
          "actionInstruction": "click the Active filter button",
          "assertions": [
            {
              "assertionId": "filter-active.completed-filter-visible",
              "type": "observe",
              "instruction": "find the Completed filter button",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "filter-active.assert-list",
          "title": "Verify only active tasks remain visible",
          "assertions": [
            {
              "assertionId": "filter-active.plan-visible",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "includes": "Plan todo benchmark"
              }
            },
            {
              "assertionId": "filter-active.draft-hidden",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "excludes": "Draft Stagehand checklist"
              }
            }
          ]
        }
      ]
    },
    "edit-task": {
      "scenarioId": "edit-task",
      "title": "Edit an existing task label",
      "source": "generated",
      "steps": [
        {
          "stepId": "edit-task.open-editor",
          "title": "Enter edit mode for the first task",
          "actionInstruction": "click the Edit button for the task Plan todo benchmark",
          "assertions": [
            {
              "assertionId": "edit-task.save-visible",
              "type": "observe",
              "instruction": "find the Save button for the task being edited",
              "exists": true,
              "method": "click"
            },
            {
              "assertionId": "edit-task.input-seeded",
              "type": "extract",
              "instruction": "extract the current value of the Edit task input",
              "resultType": "string",
              "match": {
                "equals": "Plan todo benchmark"
              }
            }
          ]
        },
        {
          "stepId": "edit-task.fill-editor",
          "title": "Update the edit draft",
          "actionInstruction": "type Plan todo benchmark outline into the Edit task input",
          "assertions": [
            {
              "assertionId": "edit-task.input-updated",
              "type": "extract",
              "instruction": "extract the current value of the Edit task input",
              "resultType": "string",
              "match": {
                "equals": "Plan todo benchmark outline"
              }
            }
          ]
        },
        {
          "stepId": "edit-task.save",
          "title": "Save the edited task",
          "actionInstruction": "click the Save button",
          "assertions": [
            {
              "assertionId": "edit-task.edit-visible",
              "type": "observe",
              "instruction": "find the Edit button for the task Plan todo benchmark outline",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "edit-task.assert-label",
          "title": "Verify the updated label is visible",
          "assertions": [
            {
              "assertionId": "edit-task.updated-visible",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "includes": "Plan todo benchmark outline"
              }
            },
            {
              "assertionId": "edit-task.original-hidden",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "excludes": "Plan todo benchmark"
              }
            }
          ]
        }
      ]
    },
    "create-delete-task": {
      "scenarioId": "create-delete-task",
      "title": "Create and remove a temporary task",
      "source": "generated",
      "steps": [
        {
          "stepId": "create-delete-task.fill-composer",
          "title": "Fill the composer with a removable task",
          "actionInstruction": "type Remove benchmark draft into the New task input",
          "assertions": [
            {
              "assertionId": "create-delete-task.composer-filled",
              "type": "extract",
              "instruction": "extract the current value of the New task input",
              "resultType": "string",
              "match": {
                "equals": "Remove benchmark draft"
              }
            }
          ]
        },
        {
          "stepId": "create-delete-task.submit",
          "title": "Create the temporary task",
          "actionInstruction": "click the Add task button",
          "assertions": [
            {
              "assertionId": "create-delete-task.remove-visible",
              "type": "observe",
              "instruction": "find the Remove button for the task Remove benchmark draft",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "create-delete-task.remove",
          "title": "Delete the temporary task",
          "actionInstruction": "click the Remove button for the task Remove benchmark draft",
          "assertions": [
            {
              "assertionId": "create-delete-task.add-button-still-visible",
              "type": "observe",
              "instruction": "find the Add task button",
              "exists": true,
              "method": "click"
            }
          ]
        },
        {
          "stepId": "create-delete-task.assert-removed",
          "title": "Verify the task is gone",
          "assertions": [
            {
              "assertionId": "create-delete-task.todo-hidden",
              "type": "extract",
              "instruction": "extract all visible todo item labels in the task list",
              "resultType": "string_array",
              "match": {
                "excludes": "Remove benchmark draft"
              }
            }
          ]
        }
      ]
    }
  },
  "benchmark": {
    "capabilities": [
      {
        "capabilityId": "smoke-load",
        "title": "Load the application",
        "scenarioIds": [
          "smoke-load"
        ]
      },
      {
        "capabilityId": "add-task",
        "title": "Add a new task",
        "scenarioIds": [
          "add-task"
        ]
      },
      {
        "capabilityId": "complete-task",
        "title": "Complete an existing task",
        "scenarioIds": [
          "complete-task"
        ]
      },
      {
        "capabilityId": "filter-active",
        "title": "Filter active tasks",
        "scenarioIds": [
          "filter-active"
        ]
      },
      {
        "capabilityId": "edit-task",
        "title": "Edit an existing task",
        "scenarioIds": [
          "edit-task"
        ]
      },
      {
        "capabilityId": "create-delete-task",
        "title": "Create and delete a task",
        "scenarioIds": [
          "create-delete-task"
        ]
      }
    ],
    "guided": {
      "capabilityIds": [
        "smoke-load",
        "add-task",
        "complete-task",
        "filter-active",
        "edit-task",
        "create-delete-task"
      ]
    },
    "explore": {
      "capabilityIds": [
        "smoke-load",
        "add-task",
        "complete-task",
        "filter-active",
        "edit-task",
        "create-delete-task"
      ],
      "heuristicTargets": {
        "minStates": 4,
        "minTransitions": 3,
        "actionKinds": [
          "navigate",
          "add",
          "toggle",
          "filter",
          "edit",
          "delete"
        ]
      },
      "canonicalStates": [
        "Initial loaded board with the seeded todos visible.",
        "A state where one todo is completed and the summary reflects progress.",
        "A state where the Active filter is selected.",
        "A state where one todo is in inline edit mode."
      ],
      "probeScenarioIds": [
        "smoke-load",
        "add-task",
        "complete-task",
        "filter-active",
        "edit-task",
        "create-delete-task"
      ]
    },
    "heal": {
      "caseIds": [
        "heal-new-task-label-lost",
        "heal-toggle-completion-noop",
        "heal-edit-task-save-noop"
      ],
      "cases": [
        {
          "caseId": "heal-new-task-label-lost",
          "title": "Repair created task labels",
          "bugId": "new-task-label-lost",
          "goldTouchedFiles": [
            "src/todo-store.js"
          ],
          "reproductionScenarioIds": [
            "add-task"
          ],
          "regressionScenarioIds": [
            "smoke-load",
            "complete-task",
            "filter-active",
            "edit-task",
            "create-delete-task"
          ]
        },
        {
          "caseId": "heal-toggle-completion-noop",
          "title": "Repair completion toggling",
          "bugId": "toggle-completion-noop",
          "goldTouchedFiles": [
            "src/todo-store.js"
          ],
          "reproductionScenarioIds": [
            "complete-task",
            "filter-active"
          ],
          "regressionScenarioIds": [
            "smoke-load",
            "add-task",
            "edit-task",
            "create-delete-task"
          ]
        },
        {
          "caseId": "heal-edit-task-save-noop",
          "title": "Repair task editing persistence",
          "bugId": "edit-task-save-noop",
          "goldTouchedFiles": [
            "src/todo-store.js"
          ],
          "reproductionScenarioIds": [
            "edit-task"
          ],
          "regressionScenarioIds": [
            "smoke-load",
            "add-task",
            "complete-task",
            "filter-active",
            "create-delete-task"
          ]
        }
      ]
    }
  },
  "bugPacks": [
    {
      "bugId": "new-task-label-lost",
      "title": "Created todos lose the user-provided label",
      "description": "New tasks are created with a fixed generic label instead of the text entered in the composer.",
      "category": "assertion",
      "severity": "medium",
      "patchPath": "patch.diff",
      "parityRules": [
        "Break only task creation text persistence.",
        "Allow the add flow to continue creating a new todo row so the failure stays observable at the assertion layer."
      ],
      "expectedFailureScenarioIds": [
        "add-task"
      ]
    },
    {
      "bugId": "toggle-completion-noop",
      "title": "Completion toggle does not update todo state",
      "description": "Clicking the checkbox leaves todo completion unchanged, so progress and active filtering remain incorrect.",
      "category": "state",
      "severity": "high",
      "patchPath": "patch.diff",
      "parityRules": [
        "Break only the completion state transition.",
        "Keep the checkbox/action visible so the runner can reproduce the failure through the normal UI."
      ],
      "expectedFailureScenarioIds": [
        "complete-task",
        "filter-active"
      ]
    },
    {
      "bugId": "edit-task-save-noop",
      "title": "Editing a todo does not persist the updated text",
      "description": "Saving an edited task leaves the original label unchanged, so the updated text never appears in the list.",
      "category": "state",
      "severity": "medium",
      "patchPath": "patch.diff",
      "parityRules": [
        "Break only edit persistence after Save or Enter.",
        "Keep edit mode, save controls, and non-edit flows operational."
      ],
      "expectedFailureScenarioIds": [
        "edit-task"
      ]
    }
  ]
}
