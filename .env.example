# Copy this file to `.env` at the repository root and fill the values you need.
# Benchmark model access and exact cost tracking both use OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# Local Stagehand browser options
STAGEHAND_LOCAL_BROWSER_PATH=
STAGEHAND_LOCAL_HEADLESS=true
STAGEHAND_LOCAL_DEVTOOLS=false
STAGEHAND_LOCAL_BROWSER_ARGS=
