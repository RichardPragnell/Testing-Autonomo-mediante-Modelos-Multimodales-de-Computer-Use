{
  "name": "agentic-qa-orchestrator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Benchmark-first hybrid lab for local Stagehand QA, exploration, diagnosis, and self-healing.",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "app:todo-react": "node node_modules/vite/bin/vite.js --config apps/todo-react/template/vite.config.js --host 127.0.0.1 --port 3101",
    "bench": "pnpm --filter @agentic-qa/harness-cli bench",
    "mcp": "pnpm --filter @agentic-qa/harness-mcp start"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@types/node": "^22.10.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.10",
    "vitest": "^3.0.0"
  }
}
