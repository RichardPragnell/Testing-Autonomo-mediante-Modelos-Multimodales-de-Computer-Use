{
  "name": "agentic-qa-orchestrator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Benchmark-first hybrid lab for local Stagehand QA, exploration, diagnosis, and self-healing.",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "app:pulse-lab": "node apps/pulse-lab/template/src/server.mjs",
    "bench": "pnpm --filter @agentic-qa/harness-cli bench",
    "mcp": "pnpm --filter @agentic-qa/harness-mcp start"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
